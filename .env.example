# =============================================================================
# BDA Workbench environment configuration
# Copy to .env and fill in real values. NEVER commit a populated .env.
# =============================================================================

# Environment: development | production
# In production the API refuses to start with insecure defaults (see below).
BDA_ENV=development

# --- Backend ---------------------------------------------------------------
BDA_DB_PATH=backend/db/bda.sqlite3
# Explicit allowlist of browser origins. Do NOT use "*" in production.
BDA_CORS_ORIGINS=http://localhost:4173,http://127.0.0.1:4173,http://localhost:5173,http://127.0.0.1:5173,http://bda.local
# REQUIRED in production: a strong random secret of >= 32 chars.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
BDA_JWT_SECRET=
BDA_JWT_EXPIRE_MINUTES=480
BDA_ARTIFACTS_BACKEND=local
BDA_COMPUTE_MODE=demo

# Upload / rate-limit guards
BDA_MAX_UPLOAD_BYTES=26214400
BDA_RATE_LIMIT_ENABLED=true
BDA_RATE_LIMIT_PER_MINUTE=300
BDA_AUTH_RATE_LIMIT_PER_MINUTE=30
# Expose Swagger docs (auto-disabled when BDA_ENV=production)
BDA_EXPOSE_DOCS=true

# Bootstrap admin password used only on first DB init (set a strong value!)
BDA_ADMIN_PASSWORD=

# --- Object storage (MinIO) ------------------------------------------------
BDA_MINIO_ENDPOINT=minio:9000
BDA_MINIO_ACCESS_KEY=
BDA_MINIO_SECRET_KEY=
BDA_MINIO_BUCKET=bda-artifacts

# --- Frontend (build-time) -------------------------------------------------
VITE_API_BASE=/api/v1

# --- Async jobs / cache ----------------------------------------------------
# REDIS_PASSWORD is required by docker-compose (redis is started with auth).
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1

# --- Copilot LLM (optional) ------------------------------------------------
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# --- PostgreSQL (optional; set BDA_DB_PATH=postgresql://bda:...@postgres:5432/bda) ---
POSTGRES_USER=bda
POSTGRES_PASSWORD=
POSTGRES_DB=bda

# --- Monitoring ------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# --- Backups (scripts/backup_db.sh) ----------------------------------------
BDA_BACKUP_DIR=./backups
BDA_BACKUP_RETENTION=14
