{
  "model": "alphafold2",
  "executable": "python /work/bme-liz/software/alphafold/run_alphafold.py",
  "scheduler": {
    "job_name": "alphafold2",
    "queue": "4v100-16-e5",
    "cpus": 8,
    "gpus": 1
  },
  "setup": [
    "module purge",
    "source activate /work/bme-liz/miniconda3/envs/alphafold"
  ],
  "parameters": {
    "fasta_paths": ["./input/complex.fasta"],
    "output_dir": "./output",
    "data_dir": "/work/bme-liz/db/alphafold",
    "uniref90_database_path": "/work/bme-liz/db/alphafold/uniref90/uniref90.fasta",
    "mgnify_database_path": "/work/bme-liz/db/alphafold/mgnify/mgy_clusters.fa",
    "template_mmcif_dir": "/work/bme-liz/db/alphafold/pdb_mmcif/mmcif_files",
    "obsolete_pdbs_path": "/work/bme-liz/db/alphafold/pdb_mmcif/obsolete.dat",
    "max_template_date": "2026-06-26",
    "model_preset": "multimer",
    "db_preset": "full_dbs",
    "models_to_relax": "best",
    "use_gpu_relax": true
  }
}
