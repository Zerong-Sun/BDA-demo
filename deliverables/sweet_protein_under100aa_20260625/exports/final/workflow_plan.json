    {
      "route_id": "monellin_redesign",
      "name": "Single-chain monellin 定向改造",
      "recommendation": "recommended",
      "generation": "first_generation",
      "rationale": "Single-chain monellin (MNEI) offers potent sweetness, a single-chain scaffold under 100 aa, engineering precedents (e.g., Mut9 with enhanced stability and sweetness), and GRAS notices (GRN 1183, 1269). Aligns with acidic beverage application via pH-stabilized mutants. Risks in thermal/process stability can be addressed by established mutations and design focus.",
      "key_risks": [
        "Thermal/process stability at beverage pH",
        "Aftertaste and off-flavors",
        "Freedom-to-operate (FTO) concerns"
      ],
      "required_evidence": [
        "Verified MNEI mutant length (<99 aa)",
        "Detailed stability data in acidic conditions",
        "Validated TAS1R2/TAS1R3 activation assay",
        "Sensory profile in target beverage matrix"
      ],
      "expected_benefits": [
        "High sweetness potency",
        "Single-chain simplicity with engineering precedent",
        "Regulatory path via existing GRAS notices",
        "Computationally tractable scaffold (PDB 2O9U)"
      ]
    },
    {
      "route_id": "brazzein_redesign",
      "name": "Brazzein-53/54 定向改造",
      "recommendation": "recommended_parallel",
      "generation": "first_generation",
      "rationale": "Brazzein (54 aa) is inherently small, heat/acid stable, and has GRAS notices (GRN 1142, 1207). Its simple fold and known surface residues for sweetness make it ideal for acidic beverages. However, correct folding of four disulfide bonds and patent crowding need mitigation. Parallel exploration reduces risk.",
      "key_risks": [
        "Correct oxidative formation of four disulfide bonds",
        "Crowded patent landscape",
        "Expression host compatibility"
      ],
      "required_evidence": [
        "Confirm brazzein-53/54 sequence and structure",
        "Disulfide mapping and folding efficiency",
        "Patent landscape analysis",
        "Stability and sweetness in acidic beverage model"
      ],
      "expected_benefits": [
        "Minimal size (<100 aa) and thermal/acid stability",
        "Established receptor mutagenesis data",
        "Alternative GRAS route"
      ]
    },
    {
      "route_id": "ph_responsive_research",
      "name": "pH-responsive 味觉修饰蛋白",
      "recommendation": "research_track",
      "generation": "second_generation",
      "rationale": "Curculin's taste-modifying, pH-responsive activity offers differentiation for acidic beverages but its chains exceed 100 aa, requires dimerization, and has no regulatory precedent. Not suitable for first-generation simple single-chain design.",
      "key_risks": [
        "Exceeds 100 aa length constraint",
        "Dimerization and potential glycosylation",
        "Acid-dependent mechanism not fully characterized",
        "Regulatory uncertainty"
      ],
      "required_evidence": [
        "Feasibility of reducing chain length below 100 aa",
        "Functional assay for pH-dependent sweetness",
        "Single-chain engineering feasibility"
      ],
      "expected_benefits": [
        "Unique taste-modifying property",
        "Potential for novel beverage sensory profiles"
      ]
    },
    {
      "route_id": "de_novo_binder",
      "name": "De novo 受体 binder",
      "recommendation": "high_risk",
      "generation": "second_generation",
      "rationale": "De novo design lacks defined receptor epitope and functional activation gate. Binding does not guarantee sweetness; high screening cost and no expression/regulatory precedent. Inadvisable until receptor regions are experimentally validated.",
