# Version control / CI
.git
.github
.gitignore

# Python caches & local envs
.venv
**/__pycache__
**/*.pyc
.pytest_cache
.ruff_cache
*.egg-info

# Node / frontend build artifacts
**/node_modules
frontend/dist
frontend/.vite

# Local data, secrets, and artifacts (never bake into images)
.env
.env.*
!.env.example
backend/db/*.sqlite3*
backend/artifacts/jobs
backend/artifacts/uploads
backend/artifacts/copilot-cluster-drafts
models

# Editor / OS noise
.DS_Store
.cursor
.idea
.vscode
*.log
.coverage
coverage.xml
htmlcov

# Docs & demo assets not needed at runtime
docs
fig
README*.md
